{"id":"shang-001","text":"桌子上放着一杯热茶。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-002","text":"我们沿着石阶走上山顶。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-003","text":"孩子每天按时上学。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-004","text":"请先上车再购买车票。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-005","text":"老师在黑板上写下题目。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-006","text":"太阳从东方缓缓升上天空。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-007","text":"她早上七点出门上班。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-008","text":"船员把货物搬上甲板。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-009","text":"墙上挂着一幅山水画。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-010","text":"会议马上就要开始了。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-011","text":"晚饭后我们到街上散步。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-012","text":"这本新书已经上架销售。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-013","text":"服务员把热菜端上桌。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-014","text":"他把申请材料上交给老师。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-015","text":"鸟儿落在高高的树枝上。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-016","text":"老人慢慢走上楼梯。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-017","text":"这篇报道登上了今天的报纸。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-018","text":"雨水顺着屋檐落到地上。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-019","text":"她穿上外套准备出门。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-020","text":"运动员走上领奖台领取奖牌。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-021","text":"湖面上漂着几片荷叶。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-022","text":"他在地图上标出了路线。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-023","text":"经理把情况如实上报。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-024","text":"晚上十点以后街道安静下来。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-025","text":"新桥上来往的车辆很多。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-026","text":"他赶上了最后一班公交车。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-027","text":"面包上涂着一层果酱。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-028","text":"课堂上同学们积极回答问题。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-029","text":"河面上升起一层薄雾。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-030","text":"他马上答应了这个请求。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-031","text":"节目很快在电视上播出。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-032","text":"孩子爬上椅子去拿玩具。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-033","text":"农民把粮食装上卡车。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-034","text":"书页上留下了一滴墨水。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-035","text":"他上前一步扶住老人。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-036","text":"露珠在草叶上闪闪发亮。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-037","text":"她上周去看望了外婆。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-038","text":"飞机已经上升到云层之上。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-039","text":"请把盖子轻轻盖上。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-040","text":"这条消息很快传到了网上。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-041","text":"他们踏上了返乡的列车。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-042","text":"父亲脸上露出了笑容。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-043","text":"花盆被搬到了阳台上。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-044","text":"小船逆流而上穿过峡谷。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-045","text":"商品上贴着清楚的价格标签。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-046","text":"她把鲜花摆上窗台。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-047","text":"游客登上城楼眺望远方。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}

{"id":"shang-049","text":"早上空气清新，适合锻炼。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}
{"id":"shang-050","text":"月亮悄悄爬上了树梢。","target_char":"上","source":"bundled_fallback","license":"public_domain","access_date":"2024-01-01","is_storable":true,"is_trainable":true,"is_publishable":false}

# Database
DATABASE_URL=postgres://sensefoundry:changeme@localhost:5432/sensefoundry
DATABASE_POOL_MAX=20

# Embedding API (cloud, OpenAI-compatible)
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-changeme
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM API (OpenAI-compatible)
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-changeme
LLM_MODEL=gpt-4o-mini

# Inference service
INFER_SERVICE_URL=http://localhost:8000
INFER_DEVICE=cpu

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=changeme

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=sensefoundry

# Keycloak OIDC
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=sensefoundry
KEYCLOAK_CLIENT_ID=backend
KEYCLOAK_CLIENT_SECRET=changeme

# Application
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=info

# Model cache (HuggingFace)
MODEL_CACHE_DIR=/models
HF_ENDPOINT=https://huggingface.co

# Authoritative dictionary gate
AUTHORITATIVE_DICT_ENABLED=false

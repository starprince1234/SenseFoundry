# Database
POSTGRES_PASSWORD=your_production_value_here
DATABASE_URL=postgresql://sensefoundry:your_production_value_here@postgres:5432/sensefoundry
DATABASE_POOL_MAX=20

# Embedding API (OpenAI-compatible)
EMBEDDING_API_URL=https://your-provider.example/v1
EMBEDDING_API_KEY=your_production_value_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM API (OpenAI-compatible)
LLM_API_URL=https://your-provider.example/v1/chat/completions
LLM_API_KEY=your_production_value_here
LLM_MODEL=your_model_name_here

# Inference service
INFER_SERVICE_URL=http://inference:8000
INFER_DEVICE=cpu

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=your_production_value_here

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_production_value_here
MINIO_SECRET_KEY=your_production_value_here
MINIO_BUCKET=sensefoundry

# Keycloak OIDC
KEYCLOAK_URL=https://identity.example
KEYCLOAK_REALM=sensefoundry
KEYCLOAK_CLIENT_ID=backend
KEYCLOAK_CLIENT_SECRET=your_production_value_here
KEYCLOAK_ADMIN_PASSWORD=your_production_value_here
PUBLIC_KEYCLOAK_ISSUER=https://identity.example/realms/sensefoundry
PUBLIC_OIDC_CLIENT_ID=frontend

# Android sync package signing (use a production-only ECDSA P-256 key pair)
SYNC_SIGNING_PRIVATE_KEY=your_production_pkcs8_private_key_here
SYNC_SIGNING_PUBLIC_KEY=your_production_x509_public_key_here

# Application
APP_PORT=8080
APP_ENV=production
LOG_LEVEL=info
PUBLIC_API_URL=https://api.example/api/v1

# Model cache (HuggingFace)
MODEL_CACHE_DIR=/models
HF_ENDPOINT=https://huggingface.co
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
MLM_MODEL_NAME=bert-base-chinese
MLM_MODEL_REVISION=main
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_MODEL_REVISION=main

# Authoritative dictionary gate
AUTHORITATIVE_DICT_ENABLED=false
